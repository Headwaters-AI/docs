{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Faces",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://faces.sh"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://faces.sh"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/faces",
              "guides/chat",
              "guides/compile",
              "guides/synthetic-faces",
              "guides/billing"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/compiled-faces",
              "concepts/centroids"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/headwaters-ai",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/headwaters-ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
